---
const { name, county, headline } = Astro.props;
---

<section class="bg-light-gray border-b-2 border-gold/20 pt-16">
  <div class=></div>
  <div class="relative z-10 container-main px-4 py-20 md:py-28">
    {county && (
      <span class="animate-fade-in-up inline-block mb-4 px-4 py-1.5 text-sm font-semibold tracking-wide uppercase rounded-full bg-white/10 text-gray-300 border border-white/20">
        {county} County
      </span>
    )}
    <h1 class="animate-fade-in-up font-heading text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight max-w-3xl">
      {headline || `Apartment Renovation in ${name}`}
    </h1>
    <div class="animate-fade-in-up-delay mt-10">
      <a href="/contact" class="btn-primary inline-block text-lg px-8 py-4">Request a Bid</a>
    </div>
  </div>
</section>
