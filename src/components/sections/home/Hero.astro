---
<section class="bg-white pt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-0 min-h-[calc(100vh-4rem)]">

      <!-- Left: Text -->
      <div class="flex flex-col justify-center py-20 lg:py-28 lg:pr-16">
        <div class="flex items-center gap-3 mb-8">
          <span class="w-8 h-px bg-gold"></span>
          <span class="text-xs font-bold uppercase tracking-[0.2em] text-gold">Houston, Texas</span>
        </div>

        <h1 class="animate-fade-in-up font-heading text-5xl md:text-6xl lg:text-7xl font-black text-charcoal leading-[1.05] tracking-tight">
          Apartment<br />
          Renovation<br />
          <span class="text-gold">That Delivers.</span>
        </h1>

        <p class="animate-fade-in-up-delay mt-8 text-lg text-gray-500 leading-relaxed max-w-md">
          Full-scope renovation programs for apartment owners and operators across the Houston metro. From bid to punchlist — precision execution, no handoffs.
        </p>

        <div class="animate-fade-in-up-delay-2 mt-10 flex flex-col sm:flex-row gap-4">
          <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 bg-charcoal text-white text-sm font-bold uppercase tracking-widest hover:bg-gold transition-colors duration-200">
            Request a Bid
          </a>
          <a href="/services" class="inline-flex items-center justify-center px-8 py-4 border-2 border-charcoal text-charcoal text-sm font-bold uppercase tracking-widest hover:bg-charcoal hover:text-white transition-colors duration-200">
            Our Services
          </a>
        </div>

        <div class="animate-fade-in-up-delay-2 mt-10 flex items-center gap-6 pt-10 border-t border-mid-gray">
          <div>
            <p class="font-heading text-3xl font-black text-charcoal">1,000+</p>
            <p class="text-xs text-gray-400 uppercase tracking-wider mt-0.5">Units Delivered</p>
          </div>
          <div class="w-px h-10 bg-mid-gray"></div>
          <div>
            <p class="font-heading text-3xl font-black text-charcoal">48hr</p>
            <p class="text-xs text-gray-400 uppercase tracking-wider mt-0.5">Bid Turnaround</p>
          </div>
          <div class="w-px h-10 bg-mid-gray"></div>
          <div>
            <p class="font-heading text-3xl font-black text-charcoal">100%</p>
            <p class="text-xs text-gray-400 uppercase tracking-wider mt-0.5">Multifamily</p>
          </div>
        </div>
      </div>

      <!-- Right: Placeholder visual -->
      <div class="hidden lg:flex flex-col">
        <div class="flex-1 bg-light-gray flex items-center justify-center relative overflow-hidden">
          <!-- Geometric accent -->
          <div class="absolute top-0 right-0 w-32 h-32 bg-gold/10"></div>
          <div class="absolute bottom-0 left-0 w-24 h-24 bg-charcoal/5"></div>
          <div class="text-center">
            <div class="w-20 h-20 rounded-full border-2 border-mid-gray flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" /></svg>
            </div>
            <p class="text-xs text-gray-300 tracking-widest uppercase">Photo coming soon</p>
          </div>
          <!-- Accent bar -->
          <div class="absolute left-0 top-1/4 bottom-1/4 w-1 bg-gold"></div>
        </div>
        <div class="bg-charcoal px-8 py-6 flex items-center justify-between">
          <p class="text-white/60 text-xs uppercase tracking-widest">Licensed &amp; Insured</p>
          <p class="text-white/60 text-xs uppercase tracking-widest">Houston Metro</p>
          <a href="tel:8323603804" class="text-gold text-sm font-bold hover:underline">(832) 360-3804</a>
        </div>
      </div>

    </div>
  </div>
</section>
