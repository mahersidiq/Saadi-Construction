---
---
<section class="bg-white pt-16 min-h-screen flex flex-col">
  <!-- Top accent bar -->
  <div class="h-1.5 bg-gold w-full"></div>

  <div class="flex-1 flex flex-col lg:flex-row">
    <!-- Left: main content -->
    <div class="flex-1 flex flex-col justify-center px-8 md:px-16 lg:px-20 py-16 lg:py-24">
      <p class="animate-fade-in-up label-tag mb-6">Houston, Texas · Multifamily Renovation</p>

      <h1 class="animate-fade-in-up font-heading font-black text-charcoal leading-[1.0] tracking-tight">
        <span class="block text-5xl md:text-7xl lg:text-8xl">Renovation</span>
        <span class="block text-5xl md:text-7xl lg:text-8xl text-gold">That</span>
        <span class="block text-5xl md:text-7xl lg:text-8xl">Delivers.</span>
      </h1>

      <p class="animate-fade-in-up-delay mt-8 text-lg text-gray-500 leading-relaxed max-w-lg">
        Full-scope apartment renovation for owners and operators who demand institutional-grade execution — from bid to punchlist.
      </p>

      <div class="animate-fade-in-up-delay-2 mt-10 flex flex-wrap gap-4">
        <a href="/contact" class="bg-gold text-white font-bold px-8 py-4 text-sm uppercase tracking-widest hover:bg-emerald-700 transition-colors">
          Request a Bid →
        </a>
        <a href="/services" class="border-2 border-charcoal text-charcoal font-bold px-8 py-4 text-sm uppercase tracking-widest hover:bg-charcoal hover:text-white transition-colors">
          Our Services
        </a>
      </div>

      <!-- Inline stats -->
      <div class="animate-fade-in-up-delay-2 mt-14 grid grid-cols-3 gap-0 border border-mid-gray divide-x divide-mid-gray max-w-sm">
        <div class="px-4 py-4 text-center">
          <p class="font-heading text-2xl font-black text-charcoal">1K+</p>
          <p class="text-[10px] uppercase tracking-widest text-gray-400 mt-0.5">Units</p>
        </div>
        <div class="px-4 py-4 text-center">
          <p class="font-heading text-2xl font-black text-gold">48hr</p>
          <p class="text-[10px] uppercase tracking-widest text-gray-400 mt-0.5">Bids</p>
        </div>
        <div class="px-4 py-4 text-center">
          <p class="font-heading text-2xl font-black text-charcoal">100%</p>
          <p class="text-[10px] uppercase tracking-widest text-gray-400 mt-0.5">Multifamily</p>
        </div>
      </div>
    </div>

    <!-- Right: hero photo panel -->
    <div class="hidden lg:flex flex-col w-[42%] relative overflow-hidden">
      <div class="absolute top-0 left-0 w-1 h-full bg-gold z-10"></div>
      <img
        src="/images/saadi-kitchen-white-island-open-living-houston-1.webp"
        alt="Renovated apartment kitchen with white island open to living area — Houston, TX"
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-charcoal/20"></div>
      <div class="relative z-10 mt-auto bg-charcoal/70 backdrop-blur-sm border-t border-gold/30 px-8 py-5 flex items-center justify-between">
        <span class="text-xs font-bold uppercase tracking-widest text-gold">Licensed &amp; Insured</span>
        <a href="tel:8323603804" class="text-xs font-bold text-white hover:text-gold transition-colors">(832) 360-3804</a>
      </div>
    </div>
  </div>
</section>
