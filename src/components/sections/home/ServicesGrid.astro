---
import { allServices } from '@/data/services';
---
<section class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-end justify-between mb-16 border-b border-mid-gray pb-8">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-gold mb-3">What We Do</p>
        <h2 class="font-heading text-4xl md:text-5xl font-black text-charcoal">Full-Scope Renovation<br />Services</h2>
      </div>
      <a href="/services" class="hidden md:inline-flex items-center gap-2 text-sm font-bold uppercase tracking-widest text-charcoal hover:text-gold transition-colors">
        All Services
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>

    <div class="divide-y divide-mid-gray">
      {allServices.map((service, i) => (
        <a
          href={`/services/${service.slug}`}
          class="group flex items-center justify-between py-6 hover:bg-light-gray -mx-4 px-4 transition-colors duration-150"
        >
          <div class="flex items-center gap-8">
            <span class="font-heading text-sm font-black text-gold/50 w-8 shrink-0">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div>
              <h3 class="font-heading text-xl font-bold text-charcoal group-hover:text-gold transition-colors">
                {service.name}
              </h3>
              <p class="text-sm text-gray-400 mt-0.5">{service.category}</p>
            </div>
          </div>
          <svg class="w-5 h-5 text-mid-gray group-hover:text-gold group-hover:translate-x-1 transition-all duration-200 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      ))}
    </div>
  </div>
</section>
