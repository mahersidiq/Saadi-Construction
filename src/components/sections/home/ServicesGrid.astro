---
import { allServices } from '@/data/services';
---
<section class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Section header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
      <div>
        <p class="label-tag mb-4">What We Do</p>
        <h2 class="font-heading text-4xl md:text-5xl font-black text-charcoal leading-tight">
          Full-Scope Renovation<br />Services
        </h2>
      </div>
      <a href="/services" class="label-tag hover:underline shrink-0">All Services →</a>
    </div>

    <!-- Two-column manifest list -->
    <div class="grid md:grid-cols-2 gap-0 border border-mid-gray divide-y md:divide-y-0 md:divide-x divide-mid-gray">
      {allServices.map((service, i) => (
        <a
          href={`/services/${service.slug}`}
          class="group flex items-center justify-between p-8 border-b border-mid-gray hover:bg-light-gray transition-colors"
        >
          <div class="flex items-center gap-6">
            <span class="font-heading text-3xl font-black text-gold/25 shrink-0 w-10">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <h3 class="font-heading text-lg font-bold text-charcoal group-hover:text-gold transition-colors">{service.name}</h3>
              <p class="text-xs uppercase tracking-widest text-gray-400 mt-0.5">{service.category}</p>
            </div>
          </div>
          <svg class="w-5 h-5 text-mid-gray group-hover:text-gold group-hover:translate-x-1 transition-all shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      ))}
    </div>
  </div>
</section>
