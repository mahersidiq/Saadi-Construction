---
const values = [
  { title: 'Multifamily-Only Focus', text: 'Every project we take is an apartment community. That specialization shows in our execution.', icon: 'building' },
  { title: 'Proven at Scale', text: 'Our team has delivered construction programs across 1,000+ multifamily units in Houston \u2014 from ground-up developments to full gut rehab programs.', icon: 'chart' },
  { title: 'Owner on Every Project', text: 'You work directly with decision-making leadership from bid to punchlist. No handoffs.', icon: 'user' },
  { title: 'Houston Subcontractor Network', text: "Deep relationships with Houston\u2019s best trade contractors across every discipline \u2014 built over years of multifamily work.", icon: 'users' },
];
---

<section class="section-padding bg-light-gray">
  <div class="container-main">
    <h2 class="animate-on-scroll font-heading text-3xl md:text-4xl font-bold text-charcoal text-center">
      Why Apartment Owners Choose Saadi
    </h2>

    <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {values.map((item) => (
        <div class="animate-on-scroll bg-white rounded-2xl p-6 shadow-md hover:shadow-xl transition-shadow duration-300">
          <div class="w-12 h-12 rounded-lg bg-navy/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 0h.008v.008h-.008V7.5z" />
            </svg>
          </div>
          <h3 class="font-heading text-lg font-bold text-charcoal mb-2">{item.title}</h3>
          <p class="text-sm text-gray-600 leading-relaxed">{item.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
