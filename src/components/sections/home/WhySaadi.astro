---
const values = [
  { stat: '1,000+', label: 'Units Delivered', text: 'Across Houston metro — from ground-up garden-style to full gut rehab programs.' },
  { stat: '48hr', label: 'Bid Turnaround', text: 'Detailed per-unit cost breakdowns delivered within 48 business hours.' },
  { stat: '100%', label: 'Multifamily Focus', text: 'Every project, every dollar, every trade relationship — built for apartments only.' },
  { stat: 'Owner-Led', label: 'Every Project', text: 'No handoffs. Decision-making leadership on-site from bid day to punchlist.' },
];
---
<section class="bg-light-gray py-24 border-y border-mid-gray">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="mb-16">
      <p class="label-tag mb-4">Why SCG</p>
      <h2 class="font-heading text-4xl md:text-5xl font-black text-charcoal">Built Different.</h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-0 border border-mid-gray divide-y sm:divide-y-0 sm:divide-x divide-mid-gray">
      {values.map((v, i) => (
        <div class="animate-on-scroll bg-white p-10 flex flex-col gap-4 hover:bg-gold/5 transition-colors">
          <div>
            <p class="font-heading text-5xl font-black text-gold leading-none">{v.stat}</p>
            <p class="text-xs font-bold uppercase tracking-widest text-charcoal mt-1">{v.label}</p>
          </div>
          <p class="text-sm text-gray-500 leading-relaxed border-t border-mid-gray pt-4">{v.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
