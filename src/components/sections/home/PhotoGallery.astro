---
const photos = [
  { src: '/images/saadi-kitchen-white-open-living-geometric-houston-1.png', alt: 'Renovated apartment kitchen and living area Houston' },
  { src: '/images/saadi-exterior-courtyard-bench-houston-1.png', alt: 'Multifamily exterior courtyard renovation Houston' },
  { src: '/images/saadi-clubhouse-fireplace-dark-wood-houston-1.png', alt: 'Clubhouse lounge renovation Houston' },
  { src: '/images/saadi-pool-deck-resort-tiki-bar-houston-1.png', alt: 'Pool deck and amenity renovation Houston' },
  { src: '/images/saadi-kitchen-dark-stone-backsplash-open-houston-1.png', alt: 'Dark kitchen renovation open layout Houston' },
  { src: '/images/saadi-clubhouse-lounge-contemporary-houston-1.png', alt: 'Contemporary clubhouse renovation Houston' },
];
---
<section class="py-4 bg-white">
  <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
    {photos.map((p) => (
      <div class="overflow-hidden h-64">
        <img
          src={p.src}
          alt={p.alt}
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      </div>
    ))}
  </div>
</section>
