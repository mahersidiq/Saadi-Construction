---
const photos = [
  { src: '/images/saadi-kitchen-white-shaker-ss-appliances-houston-1.webp', alt: 'Renovated kitchen with white shaker cabinets and stainless steel appliances' },
  { src: '/images/saadi-kitchen-gray-cabinet-island-houston-1.jpg',         alt: 'Kitchen renovation with gray cabinets and center island' },
  { src: '/images/saadi-kitchen-white-cabinet-island-houston-1.jpg',        alt: 'Kitchen with white cabinets and island' },
  { src: '/images/saadi-kitchen-render-white-black-pendants-houston-1.webp', alt: 'Rendered kitchen design with white counters and black pendant lights' },
  { src: '/images/saadi-bedroom-render-ceiling-fan-houston-1.webp',          alt: 'Rendered bedroom with ceiling fan' },
  { src: '/images/saadi-bathroom-render-double-vanity-houston-1.webp',       alt: 'Rendered bathroom with double vanity' },
  { src: '/images/saadi-kitchen-white-island-open-living-houston-1.webp',    alt: 'Kitchen with white island open to living area' },
  { src: '/images/saadi-kitchen-sage-island-patterned-tile-houston-1.webp',  alt: 'Kitchen with sage island and patterned tile backsplash' },
];
---
<section class="py-4 bg-white">
  <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
    {photos.map((photo) => (
      <div class="overflow-hidden h-64">
        <img
          src={photo.src}
          alt={photo.alt}
          class="object-cover h-64 w-full"
          loading="lazy"
        />
      </div>
    ))}
  </div>
</section>
