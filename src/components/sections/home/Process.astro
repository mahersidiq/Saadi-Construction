---
const steps = [
  { title: 'Scope & Bid', text: 'Detailed per-unit cost breakdown within 5 business days' },
  { title: 'Contract & Schedule', text: 'Fixed-price contracts with milestone-based billing' },
  { title: 'Execution', text: 'Phased delivery keeps income flowing during renovation' },
  { title: 'Punch & Handoff', text: 'Photo documentation on every unit, clean handoff to your team' },
];
---
<section class="py-24 bg-white border-t border-mid-gray">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-16">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-gold mb-3">Our Process</p>
      <h2 class="font-heading text-4xl md:text-5xl font-black text-charcoal">How We Work</h2>
    </div>

    <div class="grid md:grid-cols-4 gap-0 divide-y md:divide-y-0 md:divide-x divide-mid-gray border border-mid-gray">
      {steps.map((step, i) => (
        <div class="animate-on-scroll p-8 flex flex-col gap-4">
          <span class="font-heading text-4xl font-black text-gold/30">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <h3 class="font-heading text-lg font-bold text-charcoal">{step.title}</h3>
            <p class="text-sm text-gray-400 mt-2 leading-relaxed">{step.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
