---
const steps = [
  { num: '01', title: 'Scope & Bid', text: 'Detailed per-unit breakdown in 48 hours' },
  { num: '02', title: 'Contract', text: 'Fixed-price with milestone billing' },
  { num: '03', title: 'Execution', text: 'Phased — income keeps flowing' },
  { num: '04', title: 'Handoff', text: 'Photo docs on every unit, clean close' },
];
---
<section class="py-24 bg-white border-t border-mid-gray">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex flex-col md:flex-row md:items-center gap-16">
      <div class="shrink-0 md:w-64">
        <p class="label-tag mb-4">How We Work</p>
        <h2 class="font-heading text-4xl font-black text-charcoal">Four steps.<br/>No surprises.</h2>
        <a href="/contact" class="mt-8 inline-flex bg-gold text-white text-xs font-black uppercase tracking-[0.2em] px-6 py-3 hover:bg-emerald-700 transition-colors">
          Start Here →
        </a>
      </div>
      <div class="flex-1 grid grid-cols-2 lg:grid-cols-4 gap-0 border border-mid-gray divide-x divide-mid-gray">
        {steps.map((s) => (
          <div class="animate-on-scroll p-8 border-b border-mid-gray lg:border-b-0 flex flex-col gap-3 hover:bg-light-gray transition-colors">
            <span class="font-heading text-4xl font-black text-gold/30">{s.num}</span>
            <h3 class="font-heading text-base font-bold text-charcoal">{s.title}</h3>
            <p class="text-xs text-gray-400 leading-relaxed">{s.text}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
