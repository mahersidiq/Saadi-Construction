---
import Layout from '@/layouts/Layout.astro';
import ProjectGallery from '@/islands/ProjectGallery.jsx';
import ProjectCard from '@/components/sections/projects/ProjectCard.astro';
import { supabase } from '@/lib/supabase';

export const prerender = false;

const { slug } = Astro.params;

let project = null;
let relatedProjects = [];

try {
  if (supabase) {
    const { data } = await supabase.from('projects').select('*').eq('slug', slug).single();
    if (data) {
      project = data;
      const { data: related } = await supabase
        .from('projects')
        .select('slug, title, location, unit_count, scope_type, image_url')
        .neq('slug', slug)
        .eq('scope_type', data.scope_type || '')
        .order('created_at', { ascending: false })
        .limit(3);
      if (related) relatedProjects = related;
    }
  }
} catch (e) {
  console.error('Error fetching project:', e);
}

if (!project) {
  return new Response(
    `<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Project Coming Soon | Saadi Construction Group</title>
<script>setTimeout(()=>location.href='/projects',4000)</script></head>
<body style="margin:0;background:#1b3a5c;display:flex;align-items:center;justify-content:center;min-height:100vh;font-family:sans-serif;color:#fff;text-align:center;padding:2rem">
<div><p style="color:#c9952a;font-size:1.1rem;font-weight:600;text-transform:uppercase;letter-spacing:.1em;margin-bottom:1rem">Project Details</p>
<h1 style="font-size:2.5rem;font-weight:800;margin:0 0 1.5rem">Coming Soon</h1>
<p style="color:#9ca3af;font-size:1.1rem;max-width:480px">We're adding full project details shortly. Redirecting you back to all projects…</p>
<a href="/projects" style="display:inline-block;margin-top:2rem;padding:.9rem 2rem;background:#c9952a;color:#fff;text-decoration:none;border-radius:8px;font-weight:600">View All Projects</a></div>
</body></html>`,
    { status: 200, headers: { 'Content-Type': 'text/html' } }
  );
}

const { title, location, unit_count, scope_type, description, body, image_url, gallery } = project;
---

<Layout
  title={`${title} | Saadi Construction Group`}
  description={description || `${title} — apartment renovation project in ${location || 'Houston, TX'} by Saadi Construction Group.`}
  keywords={`apartment renovation ${location || 'Houston'}, ${scope_type || 'multifamily renovation'}`}
  canonicalUrl={`https://saadiconstructiongroup.com/projects/${slug}`}
  ogImage={image_url || '/og-image.jpg'}
>
  <!-- Hero -->
  <section class="relative min-h-[60vh] flex items-end bg-gradient-to-br from-navy via-[#14304d] to-charcoal overflow-hidden">
    {image_url && <img src={image_url} alt={title} class="absolute inset-0 w-full h-full object-cover opacity-30" />}
    <div class="absolute inset-0 bg-gradient-to-t from-navy/90 via-navy/50 to-transparent"></div>
    <div class="relative z-10 container-main px-4 pb-16 pt-32 md:pb-20">
      {scope_type && (
        <span class="animate-fade-in-up inline-block mb-4 px-4 py-1.5 text-sm font-semibold tracking-wide uppercase rounded-full bg-gold/15 text-gold border border-gold/30">{scope_type}</span>
      )}
      <h1 class="animate-fade-in-up font-heading text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight max-w-3xl">{title}</h1>
      <div class="animate-fade-in-up-delay flex flex-wrap items-center gap-4 mt-6">
        {location && (
          <span class="flex items-center gap-2 text-gray-300">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
            {location}
          </span>
        )}
        {unit_count && <span class="px-3 py-1 rounded-full bg-white/10 text-sm font-medium text-gray-300">{unit_count} Units</span>}
      </div>
    </div>
  </section>

  <!-- Description / Body -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container-main px-4">
      {description && (
        <div class="animate-on-scroll max-w-3xl mx-auto mb-12">
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-charcoal mb-6">Project Overview</h2>
          <p class="text-lg text-gray-700 leading-relaxed">{description}</p>
        </div>
      )}
      {body && (
        <div class="animate-on-scroll max-w-3xl mx-auto prose prose-lg prose-headings:font-heading prose-headings:text-charcoal prose-headings:font-bold prose-p:text-gray-700 prose-p:leading-relaxed prose-a:text-gold prose-a:font-semibold prose-strong:text-charcoal prose-img:rounded-xl" set:html={body} />
      )}
      {!description && !body && (
        <div class="animate-on-scroll max-w-3xl mx-auto text-center py-8">
          <p class="text-gray-500 text-lg">Project details coming soon.</p>
        </div>
      )}
    </div>
  </section>

  <ProjectGallery client:visible images={gallery || []} />

  {relatedProjects.length > 0 && (
    <section class="py-16 md:py-24 bg-white">
      <div class="container-main px-4">
        <h2 class="animate-on-scroll font-heading text-3xl md:text-4xl font-bold text-charcoal mb-10 text-center">Related Projects</h2>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 max-w-5xl mx-auto">
          {relatedProjects.map((p) => <ProjectCard project={p} />)}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="relative bg-navy overflow-hidden">
    <div class="absolute top-0 left-0 right-0 h-1 bg-gold"></div>
    <div class="section-padding">
      <div class="container-main text-center">
        <h2 class="animate-on-scroll font-heading text-3xl md:text-4xl font-bold text-white">Planning a Similar Renovation?</h2>
        <p class="animate-on-scroll mt-4 text-lg text-gray-300 max-w-xl mx-auto">Request a bid and let's discuss your project.</p>
        <div class="animate-on-scroll mt-8">
          <a href="/contact" class="btn-primary text-lg px-8 py-4">Request a Bid</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
