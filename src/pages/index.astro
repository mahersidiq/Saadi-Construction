---
export const prerender = true;
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/sections/home/Hero.astro';
import TrustBar from '@/components/sections/home/TrustBar.astro';
import StatsBar from '@/islands/StatsBar.jsx';
import ServicesGrid from '@/components/sections/home/ServicesGrid.astro';
import WhySaadi from '@/components/sections/home/WhySaadi.astro';
import Process from '@/components/sections/home/Process.astro';
import PhotoGallery from '@/components/sections/home/PhotoGallery.astro';
import FeaturedProjects from '@/components/sections/home/FeaturedProjects.astro';
import Testimonials from '@/components/sections/home/Testimonials.astro';
import ServiceAreas from '@/components/sections/home/ServiceAreas.astro';
import CTABanner from '@/components/sections/home/CTABanner.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'GeneralContractor',
  name: 'Saadi Construction Group',
  url: 'https://saadi-construction.vercel.app',
  telephone: '(832) 360-3804',
  email: 'Maher@saadi-construction.com',
  description: 'Houston apartment renovation contractor specializing in multifamily renovation, full gut rehabs, unit remodels, and property-wide renovation programs.',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '801 Travis St Suite 2101',
    addressLocality: 'Houston',
    addressRegion: 'TX',
    postalCode: '77002',
    addressCountry: 'US',
  },
  areaServed: { '@type': 'City', name: 'Houston', containedInPlace: { '@type': 'State', name: 'Texas' } },
};
---

<Layout
  title="Saadi Construction Group | Houston Apartment Renovation & Rehab Specialists"
  description="Houston apartment renovation contractor. Full gut rehabs, unit remodels, and complete multifamily renovation services for apartment owners and operators."
  keywords="apartment renovation Houston, multifamily renovation Houston, apartment rehab Houston TX, gut rehab apartments"
  canonicalUrl="https://saadiconstructiongroup.com"
  jsonLd={jsonLd}
>
  <Hero />
  <TrustBar />
  <StatsBar client:visible />
  <ServicesGrid />
  <WhySaadi />
  <Process />
  <PhotoGallery />
  <FeaturedProjects projects={[]} />
  <Testimonials />
  <ServiceAreas />
  <CTABanner />
</Layout>
