---
export const prerender = true;
import Layout from '@/layouts/Layout.astro';
---

<Layout
  title="Apartment Renovation Blog | Saadi Construction Group | Houston, TX"
  description="Insights on apartment renovation in Houston. Industry trends, project updates, renovation tips, cost guides, and market news for multifamily owners and operators."
  keywords="apartment renovation blog, multifamily renovation insights, Houston apartment renovation tips"
  canonicalUrl="https://saadiconstructiongroup.com/blog"
>
  <!-- Hero -->
  <section class="relative min-h-[40vh] flex items-center bg-gradient-to-br from-navy via-[#14304d] to-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(201,149,42,0.08),transparent_60%)]"></div>
    <div class="relative z-10 container-main px-4 py-20 md:py-28 text-center">
      <h1 class="animate-fade-in-up font-heading text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight">
        Apartment Renovation Insights — Houston, TX
      </h1>
    </div>
  </section>

  <!-- Coming Soon -->
  <section class="section-padding bg-white">
    <div class="container-main px-4 text-center py-16">
      <p class="text-gold font-semibold uppercase tracking-widest text-sm mb-4">Coming Soon</p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-charcoal mb-6">Articles & Renovation Insights</h2>
      <p class="text-lg text-gray-600 max-w-xl mx-auto mb-10">We're publishing guides on multifamily renovation, cost planning, and Houston market insights. Check back soon.</p>
      <a href="/contact" class="btn-primary text-lg px-8 py-4">Request a Bid</a>
    </div>
  </section>
</Layout>
