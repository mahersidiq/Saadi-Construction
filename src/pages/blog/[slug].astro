---
import Layout from '@/layouts/Layout.astro';
import { supabase } from '@/lib/supabase';

export const prerender = false;

const { slug } = Astro.params;

let post = null;
let relatedPosts = [];

try {
  if (supabase) {
    const { data, error } = await supabase
      .from('blog_posts')
      .select('*')
      .eq('slug', slug)
      .eq('status', 'published')
      .single();

    if (error || !data) return Astro.redirect('/404');
    post = data;

    if (post.category) {
      const { data: related } = await supabase
        .from('blog_posts')
        .select('slug, title, excerpt, cover_image_url, category, published_at')
        .eq('status', 'published')
        .eq('category', post.category)
        .neq('slug', slug)
        .order('published_at', { ascending: false })
        .limit(3);
      if (related) relatedPosts = related;
    }
  } else {
    return Astro.redirect('/404');
  }
} catch (e) {
  console.error('Error fetching blog post:', e);
  return Astro.redirect('/404');
}

const postUrl = `https://saadiconstructiongroup.com/blog/${slug}`;
const encodedUrl = encodeURIComponent(postUrl);
const encodedTitle = encodeURIComponent(post.title);

function formatDate(dateString) {
  if (!dateString) return '';
  return new Date(dateString).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  datePublished: post.published_at,
  dateModified: post.updated_at || post.published_at,
  author: { '@type': 'Person', name: post.author || 'Saadi Construction Group' },
  publisher: { '@type': 'Organization', name: 'Saadi Construction Group', url: 'https://saadiconstructiongroup.com' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': postUrl },
  ...(post.cover_image_url && { image: post.cover_image_url }),
  ...(post.meta_description && { description: post.meta_description }),
};
---

<Layout
  title={post.meta_title || `${post.title} | Saadi Construction Group`}
  description={post.meta_description || post.excerpt || `Read "${post.title}" on the Saadi Construction Group blog.`}
  ogImage={post.cover_image_url || '/og-image.jpg'}
  canonicalUrl={postUrl}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative min-h-[50vh] flex items-end bg-gradient-to-br from-navy via-[#14304d] to-charcoal overflow-hidden">
    {post.cover_image_url ? (
      <>
        <img src={post.cover_image_url} alt={post.title} class="absolute inset-0 w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-t from-navy/90 via-navy/50 to-transparent"></div>
      </>
    ) : (
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(201,149,42,0.1),transparent_60%)]"></div>
    )}
    <div class="relative z-10 container-main px-4 py-16 md:py-24">
      {post.category && (
        <span class="animate-fade-in-up inline-block mb-4 px-4 py-1.5 text-xs font-semibold tracking-wide uppercase rounded-full bg-gold/90 text-white">{post.category}</span>
      )}
      <h1 class="animate-fade-in-up font-heading text-3xl md:text-4xl lg:text-5xl font-extrabold text-white leading-tight max-w-3xl">{post.title}</h1>
      <div class="animate-fade-in-up-delay mt-6 flex flex-wrap items-center gap-4 text-sm text-gray-300">
        {post.published_at && <time datetime={post.published_at}>{formatDate(post.published_at)}</time>}
        {post.author && (
          <>
            <span class="text-gray-500">|</span>
            <span>{post.author}</span>
          </>
        )}
      </div>
    </div>
  </section>

  <!-- Post Body -->
  {post.content && (
    <article class="py-12 md:py-16">
      <div class="container-main px-4">
        <div class="prose prose-lg max-w-3xl mx-auto prose-headings:font-heading prose-headings:text-charcoal prose-headings:font-bold prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-4 prose-h3:text-2xl prose-h3:mt-8 prose-h3:mb-3 prose-p:text-gray-700 prose-p:leading-relaxed prose-p:mb-6 prose-a:text-gold prose-a:font-semibold prose-a:no-underline hover:prose-a:underline prose-strong:text-charcoal prose-ul:my-6 prose-ul:space-y-2 prose-ol:my-6 prose-ol:space-y-2 prose-li:text-gray-700 prose-img:rounded-xl prose-img:shadow-md prose-blockquote:border-l-4 prose-blockquote:border-gold prose-blockquote:bg-light-gray prose-blockquote:py-4 prose-blockquote:px-6 prose-blockquote:rounded-r-lg prose-blockquote:not-italic prose-blockquote:text-gray-700" set:html={post.content} />
      </div>
    </article>
  )}

  <!-- Share + CTA -->
  <section class="py-12 bg-white border-t border-gray-100">
    <div class="container-main px-4 max-w-3xl mx-auto">
      <div class="flex items-center gap-4 mb-12">
        <span class="text-sm font-semibold text-charcoal">Share:</span>
        <a href={`https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`} target="_blank" rel="noopener noreferrer" aria-label="Share on Twitter" class="inline-flex items-center justify-center h-10 w-10 rounded-full bg-light-gray border border-gray-200 text-charcoal/60 hover:bg-gold hover:text-white hover:border-gold transition-all duration-300">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" /></svg>
        </a>
        <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`} target="_blank" rel="noopener noreferrer" aria-label="Share on LinkedIn" class="inline-flex items-center justify-center h-10 w-10 rounded-full bg-light-gray border border-gray-200 text-charcoal/60 hover:bg-gold hover:text-white hover:border-gold transition-all duration-300">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" /></svg>
        </a>
        <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`} target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook" class="inline-flex items-center justify-center h-10 w-10 rounded-full bg-light-gray border border-gray-200 text-charcoal/60 hover:bg-gold hover:text-white hover:border-gold transition-all duration-300">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" /></svg>
        </a>
      </div>

      <div class="animate-on-scroll rounded-xl bg-navy p-8 md:p-10 text-center">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-white mb-3">Planning a renovation? Request a bid.</h2>
        <p class="text-gray-300 mb-6 max-w-lg mx-auto">Tell us about your property and we will put together a detailed scope and estimate.</p>
        <a href="/contact" class="btn-primary inline-block text-lg px-8 py-4">Request a Bid</a>
      </div>
    </div>
  </section>

  <!-- Related Posts -->
  {relatedPosts.length > 0 && (
    <section class="py-16 md:py-24 bg-light-gray">
      <div class="container-main px-4">
        <h2 class="animate-on-scroll font-heading text-3xl md:text-4xl font-bold text-charcoal mb-10 text-center">Related Articles</h2>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 max-w-5xl mx-auto">
          {relatedPosts.map((p) => (
            <a href={`/blog/${p.slug}`} class="group block rounded-xl overflow-hidden bg-white border border-gray-200 hover:border-gold/50 shadow-sm hover:shadow-xl transition-all duration-300 h-full">
              <div class="relative aspect-[16/9] overflow-hidden bg-gradient-to-br from-navy to-charcoal">
                {p.cover_image_url ? (
                  <img src={p.cover_image_url} alt={p.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center">
                    <svg class="h-14 w-14 text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5" /></svg>
                  </div>
                )}
                {p.category && <span class="absolute top-3 left-3 px-3 py-1 text-xs font-semibold uppercase tracking-wide rounded-full bg-gold/90 text-white">{p.category}</span>}
              </div>
              <div class="p-5">
                <h3 class="font-heading text-lg font-bold text-charcoal group-hover:text-navy transition-colors line-clamp-2">{p.title}</h3>
                {p.excerpt && <p class="mt-2 text-sm text-gray-600 leading-relaxed line-clamp-3">{p.excerpt}</p>}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
